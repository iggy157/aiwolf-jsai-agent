# Child configuration file for multi-turn mode.
# Contains LLM provider / model / prompt definitions.
# Loaded when the main config's `mode` is set to `multi_turn`.
#
# NOTE: The block-based prompt templates under prompts/ are currently
# written in Japanese. This English example keeps the prompts inline and does not
# use `{% include %}` until English-language blocks are added. See the .jp.yml
# counterpart for the block-reference format.

llm:
  type: google
  sleep_time: 3
  # When true, use separate LangChain instances and llm_message_history per request group.
  # Shared requests (initialize, daily_initialize, daily_finish) are sent to both.
  # Talk requests (talk, whisper) use llm.talk.
  # Action requests (vote, divine, guard, attack) use llm.action.
  # When false, a single llm.type model/history is used (legacy behavior).
  separate_langchain: false
  talk:
    type: google
  action:
    type: claude

openai:
  model: gpt-4o-mini
  temperature: 0.7

google:
  model: gemini-2.0-flash-lite
  temperature: 0.7

vertexai:
  model: gemini-2.0-flash-lite
  temperature: 0.7

ollama:
  model: llama3.1
  temperature: 0.7
  base_url: http://localhost:11434

claude:
  model: claude-opus-4-5-20251101
  temperature: 1.0

prompt:
  initialize: |-
    You are a werewolf game agent.
    Your name is {{ info.agent }}.
    Your role is {{ role.value }}.

    The game will now proceed. When you receive a request, please return an appropriate response in English.

    For talk requests and whisper requests, output only the content that should be spoken in the game.
    If there is a history, refer to it. If there isn't, output appropriate content.
    When you want to end your talk because you think you can't get any more information, output "Over".

    For other requests, output only the name of the agent that is the target of the action.
    A list of surviving agents that can be targeted is provided.

    {% if info.profile is not none -%}
    Your profile: {{ info.profile }}
    {%- endif %}

    Your response will be sent directly to the game, so do not include unnecessary information.
  daily_initialize: |-
    Day start request
    Day {{ info.day }}
    {% if info.medium_result is not none -%}
    Medium result: {{ info.medium_result }}
    {%- endif %}
    {% if info.divine_result is not none -%}
    Divine result: {{ info.divine_result }}
    {%- endif %}
    {% if info.executed_agent is not none -%}
    Execution result: {{ info.executed_agent }}
    {%- endif %}
    {% if info.attacked_agent is not none -%}
    Attack result: {{ info.attacked_agent }}
    {%- endif %}
    {% if info.vote_list is not none -%}
    Vote result: {{ info.vote_list }}
    {%- endif %}
    {% if info.attack_vote_list is not none -%}
    Attack vote result: {{ info.attack_vote_list }}
    {%- endif %}
  whisper: |-
    Whisper request
    History:
    {% for w in whisper_history[sent_whisper_count:] -%}
    {{ w.agent }}: {{ w.text }}
    {% endfor %}
  talk: |-
    Talk request
    History:
    {% for w in talk_history[sent_talk_count:] -%}
    {{ w.agent }}: {{ w.text }}
    {% endfor %}
  daily_finish: |-
    Day end request
    History:
    {% for w in talk_history[sent_talk_count:] -%}
    {{ w.agent }}: {{ w.text }}
    {% endfor %}
    Day {{ info.day }}
    {% if info.medium_result is not none -%}
    Medium result: {{ info.medium_result }}
    {%- endif %}
    {% if info.divine_result is not none -%}
    Divine result: {{ info.divine_result }}
    {%- endif %}
    {% if info.executed_agent is not none -%}
    Execution result: {{ info.executed_agent }}
    {%- endif %}
    {% if info.attacked_agent is not none -%}
    Attack result: {{ info.attacked_agent }}
    {%- endif %}
    {% if info.vote_list is not none -%}
    Vote result: {{ info.vote_list }}
    {%- endif %}
    {% if info.attack_vote_list is not none -%}
    Attack vote result: {{ info.attack_vote_list }}
    {%- endif %}
  divine: |-
    Divine request
    Targets:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' -%}
    {{ k }}
    {% endif -%}
    {%- endfor %}
  guard: |-
    Guard request
    Targets:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' -%}
    {{ k }}
    {% endif -%}
    {%- endfor %}
  vote: |-
    Vote request
    Targets:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' -%}
    {{ k }}
    {% endif -%}
    {%- endfor %}
  attack: |-
    Attack request
    Targets:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' -%}
    {{ k }}
    {% endif -%}
    {%- endfor %}
