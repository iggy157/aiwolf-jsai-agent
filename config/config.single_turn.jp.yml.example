# Single-turn モード用の子設定ファイル.
# LLMプロバイダ・モデル・プロンプト定義を含む.
# メインconfigの mode が single_turn のときに読み込まれる.
#
# NOTE: Step 3 で single-turn ランタイム (llm_message_history を使わず,
# initialize/daily_initialize/daily_finish の情報と talk_history 全件をプロンプトに
# 埋め込む実装) を追加する. 現時点では骨格のみ.

llm:
  type: google
  # llm 直下でも model / temperature / pricing_mode / base_url を書けば
  # 下のプロバイダセクション (openai:, google: 等) の値を上書きする (任意).
  # model: gemini-2.5-pro
  sleep_time: 3
  separate_langchain: false
  # talk / action には type の他に model / temperature / pricing_mode / base_url を直接書ける.
  # 指定した項目は下の <provider>: セクションより優先される. 省略した項目は <provider>: から継承.
  # 同じ会社の異なるモデルを使い分けたい場合はここに model を書く.
  # type を省略した場合は llm.type をデフォルトとして使う.
  talk:
    type: openai
    model: gpt-4o
  action:
    type: openai
    model: gpt-4o-mini
  # llm.thread: スレッド機能 (Step A 判断 + inference=llm 時の thread 割当) で使う第3系統.
  # 常に stateless (履歴なし) で動作し, separate_langchain の値には依存しない.
  # 軽量モデルを当てるとコスト・レイテンシを抑えられる.
  # thread.enabled=false のときは読まれない. type を省略すると llm.type をデフォルトとして使う.
  thread:
    type: anthropic
    model: claude-haiku-4-5-20251001

openai:
  model: gpt-4o-mini
  temperature: 0.7

google:
  model: gemini-2.0-flash-lite
  temperature: 0.7

vertexai:
  model: gemini-2.0-flash-lite
  temperature: 0.7

ollama:
  model: llama3.1
  temperature: 0.7
  base_url: http://localhost:11434

anthropic:
  model: claude-opus-4-5-20251101
  temperature: 1.0

# スレッド機能 (talk 履歴を自動でスレッド化し, より整理された形で LLM に渡す).
# - enabled: false なら従来挙動 (フラットな history) のまま.
# - inference: heuristic (LLM 不使用, 決定論) | llm (P5 で追加, llm.thread で推定).
# - history_days: null なら全 day 保持表示, 整数 N なら直近 N 日のみプロンプトに渡す.
# 構造ログ (log/<game>/thread_structure/<agent>.jsonl) は log.file_output と
# thread.enabled の両方が true のときに自動出力される.
thread:
  enabled: false
  inference: heuristic
  history_days: null

# single-turn モードでは llm_message_history を使わず, 毎リクエストでフルコンテキストを
# プロンプト本文に埋め込む. 各プロンプトで 5ブロック (identity / event / history / instruction / constraints)
# をすべて include する.
# initialize / daily_initialize / daily_finish は LLM に送信されず, それらで受け取った情報は
# agent 内部の day_events に蓄積され event.jinja 経由で各プロンプトに埋め込まれる.
prompt:
  talk: |-
    {{ block('identity') }}
    {{ block('game_state') }}
    {{ block('rules') }}

    # 日次イベント
    {{ block('event') }}

    # トーク履歴
    {% if thread_enabled -%}
    {{ block('thread_summary') }}
    {{ block('thread_history') }}
    {{ block('thread_context') }}
    {%- else -%}
    {% set history_source = talk_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}
    {%- endif %}

    {{ block('daily_objective') }}
    {{ block('instruction') }}
    {{ block('constraints') }}
  whisper: |-
    {{ block('identity') }}
    {{ block('game_state') }}
    {{ block('rules') }}

    # 日次イベント
    {{ block('event') }}

    # 囁き履歴
    {% set history_source = whisper_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}

    {{ block('instruction') }}
    {{ block('constraints') }}
  divine: |-
    {{ block('identity') }}

    # 日次イベント
    {{ block('event') }}

    # トーク履歴
    {% set history_source = talk_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}

    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}
  guard: |-
    {{ block('identity') }}

    # 日次イベント
    {{ block('event') }}

    # トーク履歴
    {% set history_source = talk_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}

    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}
  vote: |-
    {{ block('identity') }}

    # 日次イベント
    {{ block('event') }}

    # トーク履歴
    {% set history_source = talk_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}

    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}
  attack: |-
    {{ block('identity') }}

    # 日次イベント
    {{ block('event') }}

    # 囁き履歴
    {% set history_source = whisper_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}

    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}
